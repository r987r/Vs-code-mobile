<?xml version="1.0" encoding="utf-8"?>
<!-- Single codespace list item -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_codespace_card"
    android:padding="16dp"
    android:layout_marginBottom="10dp">

    <!-- Top row: name + status badge -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/vscode_text_highlight"
            android:textSize="15sp"
            android:fontFamily="monospace"
            android:ellipsize="end"
            android:maxLines="1" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp"
            android:textSize="11sp"
            android:textColor="@color/vscode_text_primary"
            android:background="@color/vscode_activity_bar_bg" />

    </LinearLayout>

    <!-- Repository info -->
    <TextView
        android:id="@+id/tvRepository"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/vscode_text_secondary"
        android:textSize="12sp"
        android:ellipsize="end"
        android:maxLines="1" />

    <!-- Branch info -->
    <TextView
        android:id="@+id/tvBranch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="@color/vscode_text_secondary"
        android:textSize="12sp" />

    <!-- Open button -->
    <Button
        android:id="@+id/btnOpen"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_button_primary"
        android:text="@string/open_codespace"
        android:textColor="@color/white"
        android:textSize="13sp" />

</LinearLayout>
