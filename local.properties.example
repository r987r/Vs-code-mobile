# Copy this file to local.properties and fill in your values.
# local.properties is git-ignored and must NEVER be committed.

# Path to your Android SDK installation.
# Android Studio sets this automatically; override it here if needed.
# sdk.dir=/Users/yourname/Library/Android/sdk      # macOS
# sdk.dir=/home/yourname/Android/Sdk               # Linux
# sdk.dir=C\:\\Users\\yourname\\AppData\\Local\\Android\\Sdk  # Windows

# GitHub OAuth App credentials.
# Register at: GitHub → Settings → Developer settings → OAuth Apps → New OAuth App
# Callback URL: com.vscode.mobile://oauth2redirect
GH_CLIENT_ID=YOUR_GITHUB_CLIENT_ID_HERE
GH_CLIENT_SECRET=YOUR_GITHUB_CLIENT_SECRET_HERE
